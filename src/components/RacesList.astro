---
import { getCollection } from "astro:content";
import RaceCard from "@/components/RaceCard.astro";
import MonthNav from "@/components/MonthNav.astro";

interface Race {
	title: string;
	date: string;
	location: string;
	terrain: string;
	registrationUrl?: string;
	raceOptions: number[];
	tentative?: boolean;
}

async function getAllRaces() {
	const racesData = await getCollection("races");
	const allRaces = racesData[0].data.races as Race[];
	return allRaces.sort(
		(a, b) => new Date(a.date).getTime() - new Date(b.date).getTime(),
	);
}

const races = await getAllRaces();
---

<div class="max-w-5xl mx-auto">
  <div class="max-w-3xl mx-auto px-8">
    <MonthNav races={races} />
    
    <a 
      href="#calendar"
      class="fixed bottom-6 right-6 z-50
             inline-flex items-center gap-2
             px-4 py-3 rounded-full
             bg-amber-500 text-neutral-900
             shadow-xl hover:shadow-2xl
             transition-all duration-300
             opacity-0 translate-y-2
             hover:bg-amber-600 hover:-translate-y-1
             focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2 focus:ring-offset-neutral-900
             font-['Outfit'] font-semibold"
      aria-label="Back to calendar navigation"
      id="back-to-calendar"
    >
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
      </svg>
      
      <span class="text-sm font-bold">Calendar</span>
    </a>
    
    <div class="pt-4 pb-8 space-y-6">
      {races.map((race, index) => {
        const date = new Date(race.date);
        const monthKey = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
        const prevRace = races[index - 1];
        const isFirstOfMonth = !prevRace ||
          new Date(prevRace.date).getMonth() !== date.getMonth() ||
          new Date(prevRace.date).getFullYear() !== date.getFullYear();
        const monthLabel = isFirstOfMonth ?
          date.toLocaleDateString('en-NZ', { month: 'long', year: 'numeric' }) :
          null;

        return (
          <div data-race-date={race.date} data-month-key={monthKey} class="race-item">
            {monthLabel && (
              <div class={`month-header ${index > 0 ? 'mt-10 mb-6' : 'mb-6'} flex items-center gap-3`}
                   data-month-key={monthKey}>
                <div class="flex items-center gap-2.5
                            px-3 py-2 rounded-sm
                            bg-neutral-900/60 backdrop-blur-sm
                            border border-neutral-700/30
                            shadow-md">
                  <svg class="h-4 w-4 text-neutral-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75z" clip-rule="evenodd"></path>
                  </svg>
                  <h2
                    id={monthKey}
                    class="font-['Outfit'] text-base font-semibold
                           text-neutral-200 tracking-wide scroll-mt-8"
                  >
                    {monthLabel}
                  </h2>
                </div>
                <div class="flex-1 h-px
                            bg-gradient-to-r from-neutral-700/50 via-neutral-600/30 to-transparent">
                </div>
              </div>
            )}
            <div class="transition-transform duration-300 hover:-translate-y-1 will-change-transform">
              <RaceCard race={race} />
            </div>
          </div>
        );
      })}
    </div>

    <div class="max-w-3xl mx-auto mt-4 mb-12
                p-6 rounded-sm
                bg-neutral-900/60 backdrop-blur-sm
                border border-neutral-700/30
                shadow-md">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="flex items-center gap-3">
          <svg class="h-5 w-5 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          <div>
            <h3 class="font-['Outfit'] text-sm font-semibold text-neutral-200 tracking-tight">
              Know of a race?
            </h3>
            <p class="text-xs text-neutral-400">Help us keep the calendar complete</p>
          </div>
        </div>
        <a href="mailto:ryan@gravel.co.nz"
           class="inline-flex items-center justify-center gap-2
                  px-4 py-2 rounded-sm
                  bg-amber-500/90 hover:bg-amber-500
                  text-neutral-900 font-medium text-sm
                  transition-colors duration-200
                  focus:outline-none focus:ring-2 focus:ring-amber-400 focus:ring-offset-2 focus:ring-offset-neutral-900">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Submit Race Details
        </a>
      </div>
    </div>

    <div id="no-races-message" class="text-center py-16" style="display: none;">
      <div class="mx-auto max-w-md
                  p-8 rounded-sm
                  bg-neutral-900/60 backdrop-blur-sm
                  border border-neutral-700/50">
        <svg class="mx-auto mb-4 h-12 w-12 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a4 4 0 118 0v4m-4 8l-2-2m0 0l-2-2m2 2l2-2m-2 2l2 2"/>
        </svg>
        <p class="mb-2 text-lg font-medium text-neutral-300">No upcoming races at the moment</p>
        <p class="text-sm text-neutral-400">Check back soon for new adventures!</p>
      </div>
    </div>

    <footer class="border-t border-neutral-800/50 mt-8 py-6 text-center">
      <p class="text-xs text-neutral-500">
        <span class="font-['Outfit'] font-semibold text-neutral-400">Gravel NZ</span>
        &nbsp;&middot;&nbsp; New Zealand's offroad race calendar
      </p>
    </footer>
  </div>
</div>

<script>
  // Filter past races on page load
  function filterPastRaces() {
    const now = new Date();
    now.setHours(0, 0, 0, 0);

    const raceItems = document.querySelectorAll('.race-item');
    const monthsWithVisibleRaces = new Set();
    let visibleRaceCount = 0;

    // First pass: hide past races and track which months have visible races
    raceItems.forEach(item => {
      const raceDate = new Date(item.getAttribute('data-race-date') || '');
      const monthKey = item.getAttribute('data-month-key');

      if (raceDate < now) {
        item.style.display = 'none';
      } else {
        visibleRaceCount++;
        if (monthKey) {
          monthsWithVisibleRaces.add(monthKey);
        }
      }
    });

    // Second pass: hide month headers that have no visible races
    const monthHeaders = document.querySelectorAll('.month-header');
    monthHeaders.forEach(header => {
      const monthKey = header.getAttribute('data-month-key');
      if (monthKey && !monthsWithVisibleRaces.has(monthKey)) {
        header.style.display = 'none';
      }
    });

    // Show/hide "no races" message
    const noRacesMessage = document.getElementById('no-races-message');
    if (noRacesMessage) {
      noRacesMessage.style.display = visibleRaceCount === 0 ? 'block' : 'none';
    }
  }

  // Run on page load
  filterPastRaces();

  // Back to calendar button logic
  const backButton = document.getElementById('back-to-calendar');
  const calendar = document.getElementById('calendar');

  if (backButton && calendar) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const calendarRect = calendar.getBoundingClientRect();
          const hasScrolledPastCalendar = calendarRect.bottom < 0;

          if (hasScrolledPastCalendar) {
            // User has scrolled past the calendar, show button
            backButton.style.opacity = '1';
            backButton.style.transform = 'translateY(0)';
            backButton.style.pointerEvents = 'auto';
          } else {
            // User hasn't scrolled past calendar or is above it, hide button
            backButton.style.opacity = '0';
            backButton.style.transform = 'translateY(8px)';
            backButton.style.pointerEvents = 'none';
          }
        });
      },
      { threshold: 0 }
    );

    // Also listen to scroll events for more responsive behavior
    const handleScroll = () => {
      const calendarRect = calendar.getBoundingClientRect();
      const hasScrolledPastCalendar = calendarRect.bottom < 0;

      if (hasScrolledPastCalendar) {
        backButton.style.opacity = '1';
        backButton.style.transform = 'translateY(0)';
        backButton.style.pointerEvents = 'auto';
      } else {
        backButton.style.opacity = '0';
        backButton.style.transform = 'translateY(8px)';
        backButton.style.pointerEvents = 'none';
      }
    };

    let scrollTicking = false;
    window.addEventListener('scroll', () => {
      if (!scrollTicking) {
        requestAnimationFrame(() => {
          handleScroll();
          scrollTicking = false;
        });
        scrollTicking = true;
      }
    });
    observer.observe(calendar);

    // Initial check
    handleScroll();
  }
</script> 